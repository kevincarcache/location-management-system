{
  "name": "@lms/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "uv run python -m compileall app",
    "db:bootstrap": "uv run python -m app.scripts.bootstrap_db",
    "db:migrate": "uv run alembic upgrade head",
    "db:revision": "uv run alembic revision --autogenerate -m",
    "lint": "uv run ruff check app tests",
    "typecheck": "uv run python -m compileall app",
    "test": "uv run pytest",
    "format": "uv run ruff format app tests"
  }
}
